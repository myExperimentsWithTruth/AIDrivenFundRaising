# Live donor and reconciliation data — never commit
#
# Patterns are anchored to root with a leading slash so they only match
# files in the WORKING folder, not the synthetic copies under examples/.
# The examples/ folder is committed intentionally — it is fully synthetic.

/Fundraise_Reconciliation_Sheet.xlsx
/payments_log.md
/SESSION_CONTEXT.md
/daily_updates/
/bank_stmts/
/archive/

# Excel lock and temp files, anywhere in the tree
~$*.xlsx
.~lock.*

# Date-named bank-statement folders at root (e.g. "20May", "21 May", "2026-05-22")
/[0-9][0-9]*May*/
/[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]/

# Standalone bank statement PDFs, anywhere in the tree
*STMT*.pdf
*statement*.pdf
*epassbook*.pdf

# OS / editor
.DS_Store
*.swp
*.swo
.idea/
.vscode/

# Python (if any helper scripts are added later)
__pycache__/
*.pyc
.venv/
venv/
